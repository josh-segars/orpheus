# Copy this file to .env and fill in your values.
# Never commit .env — it contains live secrets.
#
# LOCAL DEV values come from `supabase start` output.
# PROD values come from the cloud Supabase dashboard + deploy env.

# --- Supabase ---------------------------------------------------------------
# Local: printed by `supabase start` as "API URL" / "service_role key" / "anon key"
# Prod:  Settings → API in the cloud Supabase dashboard
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# --- Anthropic --------------------------------------------------------------
# For rubric scoring (Dim 1 + 4) and narrative generation.
ANTHROPIC_API_KEY=
# Optional. Overrides the pipeline default model (backend/agents.DEFAULT_MODEL,
# currently claude-sonnet-4-6). Leave unset to use the default. Any change is
# framework-affecting — re-run scripts/rubric_consistency.py before trusting
# new scores (ORPHEUS-90 / ORPHEUS-75).
ANTHROPIC_MODEL=

# --- Auth (added in ORPHEUS-23 / LinkedIn auth rollout) ---------------------
# Comma-separated list of emails allowed to hit /admin endpoints.
# Example: andrew@ess3.ai,josh@ess3.ai,tim@ess3.ai
ADMIN_EMAILS=

# Comma-separated list of frontend origins allowed by CORS.
# Dev: http://localhost:5173
# Prod: https://<your-vercel-domain>
FRONTEND_ORIGINS=http://localhost:5173

# --- LinkedIn OIDC (for Supabase CLI, only if you run `supabase start` from
# this same shell or load this file via direnv). Not read by the backend
# directly — Supabase reads them via the config.toml env() interpolation.
# --------------------------------------------------------------------------
SUPABASE_AUTH_EXTERNAL_LINKEDIN_OIDC_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_LINKEDIN_OIDC_SECRET=

# --- Resend (ORPHEUS-38, transactional email) -------------------------------
# Production key starts with `re_`. Get it from resend.com/api-keys.
# Sandbox mode: keys starting with `test_` (or the literal `test`) skip
# the network send and log the email instead — used in pytest + CI.
RESEND_API_KEY=

# Host used to build the invite link (`{APP_BASE_URL}/invite/<token>`).
# Prod: https://app.orpheussocial.com  /  Local e2e: http://localhost:5173
APP_BASE_URL=

# Token lifetime in days. Optional; defaults to 14 in backend.config.
# INVITATION_EXPIRY_DAYS=14

# --- Beta feedback email (ORPHEUS-98) ---------------------------------------
# Google Form URL for the closed-beta feedback survey — the SAME form as the
# frontend's VITE_BETA_SURVEY_URL, but the worker sends the report-completion
# email so it needs its own backend mirror. Read directly from the env by
# backend/workers/processor.py (the worker keeps its own os.environ reads).
# Read by config.Settings (admin-router advisory-publish send path) AND by
# the worker straight from os.environ (self-serve completion send path).
# Optional: when unset, the report-ready email ships with no feedback CTA
# (clean thank-you, no dead link), so prod is safe until this is configured.
# IMPORTANT: set on BOTH Railway services (backend + worker).
BETA_SURVEY_URL=
