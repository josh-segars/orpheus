# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it contains local Supabase keys (low-risk in
# dev, but we treat all env values the same).
#
# LOCAL DEV values come from `supabase start` output.
# PROD values come from your deploy platform's env settings (Vercel, etc.).

# --- Supabase ---------------------------------------------------------------
# Local: printed by `supabase start` as "API URL" and "anon key"
# Prod:  Settings → API in the cloud Supabase dashboard
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# --- Admin allowlist (client-side UX gate) ---------------------------------
# Comma-separated list of emails that see the /admin page.
# This is NOT a security boundary — the backend also enforces it via
# ADMIN_EMAILS. Keep the two lists in sync.
VITE_ADMIN_EMAILS=

# --- Backend API base URL --------------------------------------------------
# Leave blank to use same-origin (production); set to the FastAPI host
# for local dev.
VITE_API_BASE_URL=http://localhost:8000
